# Copy this file to .env and fill in your Fonepay merchant credentials.
# Used by: supabase functions serve (local dev only — never commit .env)
# For production, set these via: supabase secrets set KEY=value

FONEPAY_MERCHANT_CODE=your-merchant-code
FONEPAY_MERCHANT_SECRET=your-merchant-secret
FONEPAY_USERNAME=your-registered-phone-number
FONEPAY_PASSWORD=your-fonepay-password
